// ===========================
// Solo Plantas — Prisma Schema
// Database: PostgreSQL
// All PKs use UUID v4
// All monetary values stored as Int (cents) to avoid float errors
// ===========================

generator client {
  provider      = "prisma-client-js"
  // linux-musl-openssl-3.0.x = Alpine Linux (used in node:20-alpine Docker image)
  // native = local development (macOS / Windows / Linux host)
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===========================
// Users — Auth & Identity
// ===========================
model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique @db.VarChar(255)
  passwordHash String   @db.VarChar(255) // bcrypt hash — NEVER plain text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  userPlants UserPlant[]
  orders     Order[]

  @@map("users")
}

// ===========================
// PlantGenetics — L-System seeds
// Stores the mathematical rules that define each plant's 3D geometry
// seedJson must stay under 10 KB (10,240 bytes)
// ===========================
model PlantGenetics {
  id       String  @id @default(uuid()) @db.Uuid
  axiom    String  @db.VarChar(500)   // Starting string for L-System grammar
  rules    Json                        // Rewriting rules as JSON object
  angle    Float                       // Branching angle in degrees
  depth    Int                         // Number of L-System iterations
  seedJson String  @db.Text           // Full serialized seed (<= 10 KB)

  // Relations
  plants Plant[]

  @@map("plant_genetics")
}

// ===========================
// Plants — Catalog
// tempMin / tempMax used for climate-based recommendations
// ===========================
model Plant {
  id             String  @id @default(uuid()) @db.Uuid
  commonName     String  @db.VarChar(255)
  scientificName String  @db.VarChar(255)
  priceInCents   Int                       // Stored in MXN cents to avoid float issues
  description    String? @db.Text
  imageUrl       String? @db.VarChar(500)
  ecosystemNotes String? @db.Text
  tempMin        Float                     // Minimum ideal temperature (°C)
  tempMax        Float                     // Maximum ideal temperature (°C)
  season         String? @db.VarChar(50)  // 'spring' | 'summer' | 'fall' | 'winter' | null

  // Care guide data
  careWater       String? @db.VarChar(500)
  careLight       String? @db.VarChar(500)
  careTemperature String? @db.VarChar(500)
  careNotes       String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  lSeedId    String        @db.Uuid
  genetics   PlantGenetics @relation(fields: [lSeedId], references: [id])
  inventory  Inventory?
  userPlants UserPlant[]
  orders     Order[]

  @@map("plants")
}

// ===========================
// Inventory — Stock management (ACID transactions)
// stock    = units available for purchase
// reserved = units held in active cart reservations
// sold     = units permanently sold
// Invariant: stock + reserved + sold = total_units
// ===========================
model Inventory {
  id        String   @id @default(uuid()) @db.Uuid
  stock     Int      @default(0)   // Available to purchase
  reserved  Int      @default(0)   // Held by active cart reservations
  sold      Int      @default(0)   // Permanently sold units
  updatedAt DateTime @updatedAt

  // Relations (1:1 with Plant)
  plantId String @unique @db.Uuid
  plant   Plant  @relation(fields: [plantId], references: [id])

  cartReservations CartReservation[]

  @@map("inventory")
}

// ===========================
// CartReservations — Temporary inventory holds
// Reserved units expire after CART_RESERVATION_MINUTES (default: 10 min)
// A scheduled job (utils/tasks) releases expired reservations
// ===========================
model CartReservation {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  quantity  Int
  expiresAt DateTime                  // NOW() + CART_RESERVATION_MINUTES
  createdAt DateTime @default(now())

  // Relations
  inventoryId String    @db.Uuid
  inventory   Inventory @relation(fields: [inventoryId], references: [id])

  @@index([expiresAt])  // Index for fast expiry cleanup queries
  @@map("cart_reservations")
}

// ===========================
// UserPlants — Ownership registry
// owned=true means the user has purchased this plant
// activatedAt is set when the physical QR is scanned
// ===========================
model UserPlant {
  id          String    @id @default(uuid()) @db.Uuid
  owned       Boolean   @default(false)  // Maps directly to locked/unlocked UI state
  activatedAt DateTime?                  // Set on QR scan
  purchasedAt DateTime?                  // Set on payment confirmation

  // Relations
  userId  String @db.Uuid
  plantId String @db.Uuid
  user    User   @relation(fields: [userId], references: [id])
  plant   Plant  @relation(fields: [plantId], references: [id])

  @@unique([userId, plantId])  // One record per user-plant pair
  @@map("user_plants")
}

// ===========================
// Orders — Purchase records
// status flow: pending → confirmed → shipped → delivered → activated
// shippingType: 'delivery' | 'pickup'
// ===========================
model Order {
  id                   String   @id @default(uuid()) @db.Uuid
  status               String   @default("pending") @db.VarChar(50)
  shippingType         String   @db.VarChar(20)       // 'delivery' | 'pickup'
  totalAmountCents     Int                             // Total charged in MXN cents
  shippingFeeCents     Int      @default(0)            // 9900 (99 MXN) for delivery, 0 for pickup
  stripePaymentIntentId String? @db.VarChar(255)       // PaymentIntent ID for Stripe reconciliation
  trackingNumber       String? @db.VarChar(255)
  shippingAddress      String? @db.Text                // JSON string of delivery address
  nurseryId            String? @db.Uuid                // For pickup orders
  activatedAt          DateTime?                       // Set when QR is scanned
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  // Relations
  userId  String  @db.Uuid
  plantId String  @db.Uuid
  user    User    @relation(fields: [userId], references: [id])
  plant   Plant   @relation(fields: [plantId], references: [id])
  nursery Nursery? @relation(fields: [nurseryId], references: [id])

  @@index([userId])
  @@index([status])
  @@map("orders")
}

// ===========================
// Nurseries — Pickup locations
// Physical plant nurseries shown on the MapKit map
// ===========================
model Nursery {
  id       String  @id @default(uuid()) @db.Uuid
  name     String  @db.VarChar(255)
  address  String  @db.VarChar(500)
  lat      Float                       // Latitude for MapKit pin
  lon      Float                       // Longitude for MapKit pin
  schedule String? @db.VarChar(500)   // e.g. "Lun-Vie 9am-6pm"
  phone    String? @db.VarChar(50)

  // Relations
  orders Order[]

  @@map("nurseries")
}
