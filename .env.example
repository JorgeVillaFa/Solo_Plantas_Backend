# ===========================
# Solo Plantas API — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ===========================

# ---- Server ----
NODE_ENV=development
PORT=5001

# ---- PostgreSQL ----
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public
DATABASE_URL="postgresql://soloplantasuser:soloplantaspass@localhost:5432/soloplantasdb?schema=public"

# ---- Authentication ----
# Generate a strong random secret: openssl rand -base64 64
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# ---- CORS ----
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ---- Stripe ----
# Only test keys (sk_test_*) are allowed in this project
STRIPE_SECRET_KEY=sk_test_YOUR_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# ---- OpenWeather API ----
# Used for climate-based plant recommendations
OPENWEATHER_API_KEY=your_openweather_api_key_here

# ---- OpenAI (Chatbot) ----
OPENAI_API_KEY=sk-your_openai_api_key_here

# ---- Cart Reservations ----
# How long (in minutes) inventory is held in cart before being released
CART_RESERVATION_MINUTES=10
